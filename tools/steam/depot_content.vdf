// One depot holding all three OS builds (windows/ macos/ linux/ subfolders).
// Launch Options in the dashboard pick the right executable per OS.
"DepotBuildConfig"
{
	"DepotID"	"4933641"
	// no contentroot here — it inherits the appbuild's contentroot (../../dist/steam/content).
	// A contentroot in the depot file is resolved RELATIVE to the app's, which would double the path.
	"FileMapping" { "LocalPath" "*" "DepotPath" "." "recursive" "1" }
}
